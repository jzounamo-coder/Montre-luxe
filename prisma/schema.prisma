generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id           String   @id @default(dbgenerated("gen_random_uuid()"))
  name         String
  description  String
  price        Float
  image        String
  category     String
  gender       String
  functionType String
  stock        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  password  String
  isAdmin   Boolean    @default(false)
  createdAt DateTime   @default(now())
  // On ajoute cette ligne pour que l'utilisateur puisse avoir des commandes
  commandes Commande[] 
}

model Commande {
  id            String   @id @default(uuid())
  createdAt     DateTime @default(now())
  total         Float
  statut        String   @default("En attente")
  
  // On lie la commande au modèle "User" défini plus haut
  userId        String
  user          User     @relation(fields: [userId], references: [id])
}

model Favorite {
  id        String  @id @default(uuid())
  userId    String
  productId String
  user      User    @relation(fields: [userId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}